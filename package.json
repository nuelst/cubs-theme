{
  "name": "cubs-theme",
  "displayName": "Cubs Theme",
  "description": "A minimal VSCode theme with three variants - Midnight, Light and Shadow",
  "version": "1.0.1",
  "publisher": "nuelst",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuelst/cubs-theme"
  },
  "engines": {
    "vscode": "^1.22.0"
  },
  "categories": [
    "Themes"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#111422",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "Cubs Dark",
        "uiTheme": "vs-dark",
        "path": "./theme/cubs-dark-color-theme.json"
      },
      {
        "label": "Cubs Light",
        "uiTheme": "vs",
        "path": "./theme/cubs-light-color-theme.json"
      },
      {
        "label": "Cubs Shadow",
        "uiTheme": "vs-dark",
        "path": "./theme/cubs-shadow-theme.json"
      }
    ]
  },
  "license": "MIT",
  "author": "manuel",
  "keywords": [
    "theme",
    "dark",
    "light",
    "minimal"
  ],
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "vsce": "^2.15.0"
  },
  "scripts": {
    "package": "vsce package --no-yarn",
    "publish": "vsce publish --no-yarn"
  }
}